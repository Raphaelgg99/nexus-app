# Images built by GitHub Actions. The deploy workflow fills these automatically.
BACKEND_IMAGE=ghcr.io/OWNER/REPOSITORY/backend:latest
FRONTEND_IMAGE=ghcr.io/OWNER/REPOSITORY/frontend:latest

# Public port exposed on the VPS.
HTTP_PORT=8088

# Public frontend URL, used by CORS. Example: https://app.seudominio.com
FRONTEND_URL=https://app.seudominio.com

# Supabase Postgres connection. Prefer the Transaction Pooler for VPS deploys when appropriate.
POSTGRES_HOST=aws-0-sa-east-1.pooler.supabase.com
POSTGRES_PORT=6543
POSTGRES_DB=postgres
POSTGRES_USER=postgres.PROJECT_REF
POSTGRES_PASSWORD=change-me
POSTGRES_SSL_MODE=require
# Use &prepareThreshold=0 when using Supabase Transaction Pooler.
POSTGRES_JDBC_PARAMS=&prepareThreshold=0

# Application secrets.
JWT_SECRET=change-me
SECRET_KEY=change-me
JWT_EXPIRATION=86400000
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
OPENAI_ACCESS_TOKEN=change-me
NANOBANANA_ACCESS_TOKEN=change-me
